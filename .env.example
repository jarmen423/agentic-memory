# Agentic Memory - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# NEO4J DATABASE
# ============================================================================

# Neo4j connection URI
# - Local Neo4j: bolt://localhost:7687
# - Neo4j Aura: neo4j+s://your-instance.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Note: Neo4j 5.18+ is required for vector index support

# ============================================================================
# EMBEDDING PROVIDERS
# ============================================================================

# Default code embedding provider: Gemini
# The setup wizard now defaults code memory to Gemini so it can share the same
# embedding family as the rest of the multimodal Agentic Memory system.
#
# Google AI Studio / Gemini API key:
# - Preferred env vars: GEMINI_API_KEY or GOOGLE_API_KEY
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: if you want to keep code memory completely separate, you can switch
# the code module to another text embedding provider such as OpenAI:
# CODE_EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: explicit code-module overrides
# CODE_EMBEDDING_PROVIDER=gemini
# CODE_EMBEDDING_MODEL=gemini-embedding-2-preview
# CODE_EMBEDDING_DIMENSIONS=3072

# ============================================================================
# OPTIONAL SHARED RERANKING
# ============================================================================

# Enable the shared learned reranker across code, research, and conversation
# retrieval surfaces. Disabled by default so existing installs keep the current
# behavior unless you opt in.
#
# Supported provider today: Cohere v2 Rerank API
# AM_RERANK_ENABLED=true
# AM_RERANK_PROVIDER=cohere
# AM_RERANK_MODEL=rerank-v4.0-fast
# AM_RERANK_TIMEOUT_MS=2500
# AM_RERANK_MAX_TOKENS_PER_DOC=2048
# AM_RERANK_ABSTAIN_THRESHOLD=0.35
# AM_RERANK_CLIENT_NAME=agentic-memory
# COHERE_API_KEY=your-cohere-api-key-here
#
# Optional narrow failover path. Keep direct Cohere as primary and only use
# OpenRouter for retryable provider failures such as timeouts, 429s, or 5xxs.
# AM_RERANK_FALLBACK_PROVIDER=openrouter
# AM_RERANK_FALLBACK_MODEL=cohere/rerank-4-fast
# OPENROUTER_API_KEY=your-openrouter-api-key-here
#
# Optional per-domain candidate pool sizes used before final reranking:
# AM_CODE_DENSE_TOP_K=30
# AM_CODE_LEXICAL_TOP_K=30
# AM_CODE_RERANK_TOP_K=40
# AM_WEB_RERANK_TOP_K=30
# AM_CONVERSATION_RERANK_TOP_K=20

# ============================================================================
# INGESTION SETTINGS
# ============================================================================

# Optional: Repository path to index (can also be passed as CLI argument)
# REPO_PATH=/path/to/your/codebase

# Optional: Supported file extensions (comma-separated)
# SUPPORTED_EXTENSIONS=.py,.js,.ts,.tsx,.jsx

# Optional: Directories to ignore during indexing (comma-separated)
# IGNORE_DIRS=node_modules,__pycache__,.git,dist,build,.venv,venv

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# ============================================================================
# MCP SERVER
# ============================================================================

# Optional: Port for MCP server (default: varies by client)
# MCP_PORT=8000

# Hosted public publication base URL for legal pages and marketplace-facing MCP
# endpoints. Set this in deployed environments once you have the real public
# hostname. Examples:
# AM_PUBLIC_BASE_URL=https://mcp.example.com
# AM_PUBLIC_BASE_URL=https://agentic-memory.your-subdomain.workers.dev
