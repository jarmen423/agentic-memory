# Agentic Memory managed-backend production example.
# Copy this to `.env.production` before rendering docker-compose.prod.yml.

NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-real-password
#
# Production VM today: Neo4j listens on Bolt port 7667 (not 7687). Same-VM
# systemd am-server uses loopback — see deploy/systemd/am-server.env.example.
#
# Docker on the VM, Neo4j on the host (7667):
#   NEO4J_URI=bolt://host.docker.internal:7667
# Same-VM process (preferred when Neo4j is loopback-only): run am-server under
# systemd, not Compose; use:
#   NEO4J_URI=bolt://127.0.0.1:7667
# Bundled compose Neo4j service (default Bolt 7687 in compose file):
#   NEO4J_URI=bolt://neo4j:7687
#
# Remote tools on Tailscale (Neo4j Browser from your laptop): connect to
# bolt://<vm-tailscale-ip>:7667 — that is not the URI for colocated am-server.
NEO4J_URI=bolt://host.docker.internal:7667

AM_SERVER_API_KEYS=replace-with-real-rest-key
AGENTIC_MEMORY_DEPLOYMENT_MODE=managed
AGENTIC_MEMORY_HOSTED_BASE_URL=https://backend.agentmemorylabs.com
AM_PUBLIC_BASE_URL=https://mcp.agentmemorylabs.com

# Configure at least one provider path that matches your exposed workloads.
GOOGLE_API_KEY=replace-with-real-key
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Optional hosted-MCP surface keys
AM_SERVER_PUBLIC_MCP_API_KEYS=
AM_SERVER_INTERNAL_MCP_API_KEYS=

# Optional temporal bridge wiring
STDB_URI=
STDB_MODULE_NAME=agentic-memory-temporal
STDB_BINDINGS_MODULE=

# Optional bind overrides
AM_SERVER_EXTERNAL_PORT=8765
AM_SERVER_BIND_ADDRESS=0.0.0.0
NEO4J_HTTP_BIND_ADDRESS=127.0.0.1
NEO4J_BOLT_BIND_ADDRESS=127.0.0.1
