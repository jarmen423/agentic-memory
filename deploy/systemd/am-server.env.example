# Copy to /etc/agentic-memory/am-server.env and replace placeholder secrets.
# This file is intended for the current hosted deployment shape:
# - am-server bound to loopback on the VM
# - Cloudflare Tunnel publishes https://backend.agentmemorylabs.com
# - Neo4j already runs on the VM on port 7667 (Bolt)

AM_SERVER_HOST=127.0.0.1
AM_SERVER_PORT=8765

# Neo4j: use loopback when am-server and Neo4j run on the same VM (production path).
NEO4J_URI=bolt://127.0.0.1:7667
#
# Do not use the VM's Tailscale IP here for colocated services—loopback avoids
# routing/firewall surprises. Reserve bolt://<vm-tailscale-ip>:7667 for clients
# that reach Neo4j from another machine on the tailnet (Browser, ad-hoc tools).
# Example tailnet form (do not copy literally): bolt://100.x.x.x:7667
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-real-password

# Optional: route specific OpenClaw workspace_id values to a second Neo4j (operator private DB).
# Same HTTPS URL for everyone; routing is server-side only.
# NEO4J_OPERATOR_URI=bolt://127.0.0.1:7667
# NEO4J_OPERATOR_USER=
# NEO4J_OPERATOR_PASSWORD=
# AM_OPERATOR_WORKSPACE_IDS=your-openclaw-workspace-id

AM_SERVER_API_KEYS=replace-with-real-api-key
AGENTIC_MEMORY_DEPLOYMENT_MODE=managed
AGENTIC_MEMORY_HOSTED_BASE_URL=https://backend.agentmemorylabs.com
AM_PUBLIC_BASE_URL=https://mcp.agentmemorylabs.com

# Configure at least one provider path that matches your workloads.
GOOGLE_API_KEY=replace-with-real-key
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Recommended for authenticated reviewer access: use a dedicated public MCP key
# that is different from the backend/operator key.
AM_SERVER_PUBLIC_MCP_API_KEYS=replace-with-dedicated-public-mcp-key
AM_SERVER_INTERNAL_MCP_API_KEYS=

# Optional temporal bridge wiring.
STDB_URI=
STDB_MODULE_NAME=agentic-memory-temporal
STDB_BINDINGS_MODULE=
